---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VerificationBadge from '../../components/VerificationBadge.astro';

const tiers = [
  {
    status: 'community' as const,
    icon: '⬜',
    title: 'Community',
    color: 'border-gray-500/30 bg-gray-500/5',
    accentColor: 'text-gray-400',
    number: 'Tier 1',
    what: 'Self-reported. Robot exists and was submitted by a real person. No independent vetting or cross-checking.',
    who: 'Anyone. Submit a robot via the registry form and it immediately receives Community tier.',
    trust: 'Lowest. Do not rely on Community-tier records for safety-critical decisions.',
    how: 'Automatic on submission. No additional steps required.',
    requirements: ['Valid submission form', 'Contact email', 'Plausible manufacturer and model name'],
    useCases: ['Open-source hobby robots', 'Research prototypes', 'First-generation commercial robots establishing presence in the registry'],
  },
  {
    status: 'verified' as const,
    icon: '🟡',
    title: 'Verified',
    color: 'border-amber-500/30 bg-amber-500/5',
    accentColor: 'text-amber-400',
    number: 'Tier 2',
    what: 'Basic verification: the manufacturer exists, the model is real, and the serial number has been cross-checked where possible.',
    who: 'Any robot whose manufacturer can be independently confirmed as a real entity.',
    trust: 'Moderate. Manufacturer and model have been confirmed, but the specific robot unit has not been inspected.',
    how: 'The RRF reviews the submission against public records and available manufacturer documentation.',
    requirements: ['Manufacturer is a registered legal entity', 'Model appears in manufacturer public records or product pages', 'Serial number format is consistent with manufacturer\'s documented scheme'],
    useCases: ['Commercial robots from known manufacturers', 'Robots used in regulated environments requiring documentation', 'Insurance and procurement workflows'],
  },
  {
    status: 'certified' as const,
    icon: '🔵',
    title: 'Certified',
    color: 'border-blue-500/30 bg-blue-500/5',
    accentColor: 'text-blue-400',
    number: 'Tier 3',
    what: 'The manufacturer organization itself has been verified by the RRF. All robots from this manufacturer automatically carry Certified verification.',
    who: 'Robots from manufacturers that have gone through the RRF manufacturer verification program.',
    trust: 'High. The manufacturer has signed agreements with the RRF and takes responsibility for the accuracy of all registrations under their namespace.',
    how: 'Manufacturer applies for RRF membership at Supporting Member tier. RRF verifies legal entity, reviews governance documents, and signs a data accuracy agreement.',
    requirements: ['Manufacturer is an RRF Supporting Member', 'Signed data accuracy agreement', 'Designated registry contact at the manufacturer', 'Manufacturer-issued serial numbers follow documented scheme'],
    useCases: ['Robots deployed in enterprise environments', 'Robots subject to EU AI Act registration requirements', 'Robots used in safety-critical infrastructure'],
  },
  {
    status: 'accredited' as const,
    icon: '✅',
    title: 'Accredited',
    color: 'border-emerald-500/30 bg-emerald-500/5',
    accentColor: 'text-emerald-400',
    number: 'Tier 4',
    what: 'Full conformance audit. The robot has passed the RCAN conformance test suite (L1/L2/L3) and carries a signed conformance certificate.',
    who: 'Robots that implement the RCAN protocol and have passed all three conformance levels.',
    trust: 'Highest. The robot\'s identity, communication protocol, and reporting have all been independently audited.',
    how: 'Robot owner runs the RCAN conformance test suite and submits results. RRF issues a signed certificate with a cryptographic root of trust.',
    requirements: ['Must hold Certified tier', 'Must pass RCAN L1 (Identity), L2 (Communication), and L3 (Reporting) conformance tests', 'RURI must be present and resolvable', 'Certificate must be renewed annually or after major firmware updates'],
    useCases: ['Robots deployed in regulated environments requiring verifiable identity', 'Swarm safety applications', 'Robots subject to ISO/TC 299 compliance', 'Insurance underwriting for autonomous systems'],
  },
];
---

<BaseLayout
  title="Verification Tiers"
  description="The Robot Registry Foundation's 4-tier verification system — from community self-reporting to full RCAN conformance certification."
>

  <div class="pt-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-text-muted font-mono mb-8">
      <a href="/" class="hover:text-accent transition-colors">RRF</a>
      <span>/</span>
      <span class="text-text">Verification</span>
    </div>

    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-4xl md:text-5xl font-semibold text-text mb-4">How Verification Works</h1>
      <p class="text-lg text-text-muted mb-12 leading-relaxed">
        Not all registry entries are equal. The RRF's 4-tier verification system lets you understand
        exactly how much confidence to place in a robot's identity record.
      </p>

      <!-- Tier overview -->
      <div class="grid grid-cols-4 gap-2 mb-12 p-4 bg-bg-card border border-border rounded-xl">
        {tiers.map((tier, i) => (
          <a href={`#tier-${i+1}`} class="flex flex-col items-center p-3 rounded-lg hover:bg-white/5 transition-colors group text-center">
            <span class="text-2xl mb-1">{tier.icon}</span>
            <span class="text-xs font-mono text-text-faint group-hover:text-accent transition-colors">{tier.number}</span>
            <span class="text-xs text-text-muted mt-0.5">{tier.title}</span>
          </a>
        ))}
      </div>

      <!-- Tier detail cards -->
      <div class="space-y-8">
        {tiers.map((tier, i) => (
          <div id={`tier-${i+1}`} class:list={["border rounded-xl overflow-hidden", tier.color]}>
            <div class="p-6 border-b border-white/5">
              <div class="flex items-center gap-3 mb-4">
                <VerificationBadge status={tier.status} />
                <span class:list={["text-xs font-mono", tier.accentColor]}>{tier.number}</span>
              </div>
              <h2 class="font-display text-2xl font-semibold text-text mb-2">{tier.icon} {tier.title}</h2>
              <p class="text-text-muted leading-relaxed">{tier.what}</p>
            </div>

            <div class="grid md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-white/5">
              <div class="p-6">
                <h3 class="text-xs font-mono text-text-faint uppercase tracking-wider mb-3">Requirements</h3>
                <ul class="space-y-1.5">
                  {tier.requirements.map(req => (
                    <li class="flex gap-2 text-sm text-text-muted">
                      <span class:list={["mt-0.5 flex-shrink-0", tier.accentColor]}>→</span>
                      {req}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="p-6">
                <h3 class="text-xs font-mono text-text-faint uppercase tracking-wider mb-3">Use Cases</h3>
                <ul class="space-y-1.5">
                  {tier.useCases.map(uc => (
                    <li class="flex gap-2 text-sm text-text-muted">
                      <span class:list={["mt-0.5 flex-shrink-0", tier.accentColor]}>·</span>
                      {uc}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="px-6 pb-5 pt-4 bg-black/10 text-sm">
              <span class="text-text-faint font-mono text-xs uppercase tracking-wider">Trust level: </span>
              <span class="text-text-muted">{tier.trust}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 p-6 bg-bg-card border border-border rounded-xl text-center">
        <h3 class="font-display text-xl font-semibold text-text mb-2">Ready to register?</h3>
        <p class="text-text-muted text-sm mb-5">All new robots start at Community tier. Verification upgrades are requested after registration.</p>
        <a href="/registry/submit/" class="px-6 py-2.5 rounded-lg bg-primary hover:bg-primary-hover text-white font-medium text-sm transition-colors">
          Register Your Robot
        </a>
      </div>
    </div>
  </div>

</BaseLayout>
