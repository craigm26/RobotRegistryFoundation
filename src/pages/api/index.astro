---
import BaseLayout from '../../layouts/BaseLayout.astro';

// v2 entity endpoints — RCAN v2.2 §21
const entityEndpoints = [
  // ── Robots (RRN) ──────────────────────────────────────────────────────────
  {
    group: "Robots (RRN)",
    color: "text-accent border-accent/30 bg-primary/10",
    endpoints: [
      {
        method: "POST", path: "/v2/robots/register",
        summary: "Register a robot — receive an RRN",
        description: "Assigns the next sequential RRN (Robot Registration Number). Required fields: name, manufacturer, model, firmware_version, rcan_version. Optional: pq_signing_pub (ML-DSA-65 public key, base64), pq_kid, ruri, owner_uid.",
        body: [
          { name: "name",             type: "string",  required: true,  desc: "Human-readable robot name" },
          { name: "manufacturer",     type: "string",  required: true,  desc: "Manufacturer or team name" },
          { name: "model",            type: "string",  required: true,  desc: "Model/product identifier" },
          { name: "firmware_version", type: "string",  required: true,  desc: "Installed firmware version string" },
          { name: "rcan_version",     type: "string",  required: true,  desc: "RCAN spec version (must be \"2.2\")" },
          { name: "pq_signing_pub",   type: "string",  required: false, desc: "ML-DSA-65 public key (base64-encoded, NIST FIPS 204)" },
          { name: "pq_kid",           type: "string",  required: false, desc: "Key ID — 8-char hex (sha256 of pub key prefix)" },
          { name: "ruri",             type: "string",  required: false, desc: "RCAN Robot URI: rcan://{domain}/{org}/{model}/{unit}" },
          { name: "loa_enforcement",  type: "boolean", required: false, desc: "LoA enforcement enabled (default: true)" },
          { name: "owner_uid",        type: "string",  required: false, desc: "Firebase UID of registrant" },
        ],
        example: `{
  "rrn": "RRN-000000000001",
  "registered_at": "2026-03-27T00:00:00.000Z",
  "record_url": "https://robotregistryfoundation.org/v2/robots/RRN-000000000001"
}`,
      },
      {
        method: "GET", path: "/v2/robots/{rrn}",
        summary: "Get full robot record by RRN",
        description: "Returns the complete registry record for a robot. The RRN must follow the 12-digit zero-padded format (RRN-000000000001).",
        body: [
          { name: "rrn", type: "path", required: true, desc: "Robot Registration Number (RRN-XXXXXXXXXXXX)" },
        ],
        example: `{
  "rrn": "RRN-000000000001",
  "name": "OpenCastor Bob",
  "manufacturer": "ContinuonAI",
  "model": "opencastor-rpi5",
  "firmware_version": "v2026.3.27.1",
  "rcan_version": "2.2",
  "pq_kid": "7c21bf58",
  "loa_enforcement": true,
  "components": ["RCN-000000000001"],
  "registered_at": "2026-03-27T00:00:00.000Z"
}`,
      },
      {
        method: "GET", path: "/v2/robots/{rrn}/sbom",
        summary: "Get or publish robot SBOM",
        description: "GET: retrieve the published SBOM for a robot. POST: publish a new SBOM (requires RRF bearer token). SBOM is countersigned by the RRF root key (ML-DSA-65).",
        body: [],
        example: `{
  "rrn": "RRN-000000000001",
  "sbom_format": "spdx-json",
  "rrf_countersig": "Aj7IavBH...",
  "published_at": "2026-03-27T00:00:00.000Z"
}`,
      },
    ],
  },
  // ── Components (RCN) ──────────────────────────────────────────────────────
  {
    group: "Components (RCN)",
    color: "text-cyan-400 border-cyan-500/30 bg-cyan-500/10",
    endpoints: [
      {
        method: "POST", path: "/v2/components/register",
        summary: "Register a hardware component — receive an RCN",
        description: "Assigns the next sequential RCN (Robot Component Number). Links to a parent robot via parent_rrn. The parent robot must already be registered.",
        body: [
          { name: "parent_rrn",       type: "string",  required: true,  desc: "RRN of the owning robot (must exist in registry)" },
          { name: "type",             type: "string",  required: true,  desc: "cpu | npu | gpu | camera | lidar | imu | actuator | sensor | battery | communication | other" },
          { name: "model",            type: "string",  required: true,  desc: "Component model identifier" },
          { name: "manufacturer",     type: "string",  required: true,  desc: "Component manufacturer" },
          { name: "firmware_version", type: "string",  required: false, desc: "Component firmware version" },
          { name: "serial_number",    type: "string",  required: false, desc: "Physical serial number (if available)" },
          { name: "capabilities",     type: "array",   required: false, desc: "Capability tags (e.g. [\"rgb\", \"depth\", \"npu:hailo8\"])" },
          { name: "specs",            type: "object",  required: false, desc: "Free-form hardware specs key-value map" },
        ],
        example: `{
  "rcn": "RCN-000000000001",
  "parent_rrn": "RRN-000000000001",
  "registered_at": "2026-03-27T00:00:00.000Z",
  "record_url": "https://robotregistryfoundation.org/v2/components/RCN-000000000001"
}`,
      },
      {
        method: "GET", path: "/v2/components/{rcn}",
        summary: "Get component record by RCN",
        description: "Returns the full registry record for a hardware component.",
        body: [
          { name: "rcn", type: "path", required: true, desc: "Robot Component Number (RCN-XXXXXXXXXXXX)" },
        ],
        example: `{
  "rcn": "RCN-000000000001",
  "parent_rrn": "RRN-000000000001",
  "type": "npu",
  "model": "Hailo-8",
  "manufacturer": "Hailo",
  "capabilities": ["tops:26", "power:2.5W"],
  "registered_at": "2026-03-27T00:00:00.000Z"
}`,
      },
    ],
  },
  // ── AI Models (RMN) ───────────────────────────────────────────────────────
  {
    group: "AI Models (RMN)",
    color: "text-purple-400 border-purple-500/30 bg-purple-500/10",
    endpoints: [
      {
        method: "POST", path: "/v2/models/register",
        summary: "Register an AI model — receive an RMN",
        description: "Assigns the next sequential RMN (Robot Model Number). Tracks the AI model provenance chain required by EU AI Act Art. 11.",
        body: [
          { name: "name",              type: "string",  required: true,  desc: "Model name (e.g. \"LeWorldModel\")" },
          { name: "version",           type: "string",  required: true,  desc: "Semantic version string" },
          { name: "model_family",      type: "string",  required: true,  desc: "vision | language | multimodal | vla | embedding | reward | world_model | diffusion | other" },
          { name: "architecture",      type: "string",  required: false, desc: "Model architecture (e.g. \"jepa\", \"transformer\")" },
          { name: "parameter_count_b", type: "number",  required: false, desc: "Parameter count in billions (e.g. 0.015 = 15M params)" },
          { name: "quantization",      type: "string",  required: false, desc: "fp32 | fp16 | bf16 | int8 | int4 | gguf | bnb4 | other" },
          { name: "license",           type: "string",  required: false, desc: "SPDX license identifier (e.g. \"apache-2.0\")" },
          { name: "provider",          type: "string",  required: false, desc: "huggingface | ollama | openai | anthropic | local" },
          { name: "provider_model_id", type: "string",  required: false, desc: "Provider-native model ID (e.g. \"meta-llama/Llama-3-8B-Instruct\")" },
          { name: "repo_url",          type: "string",  required: false, desc: "Source repository URL" },
          { name: "rcan_compatible",   type: "boolean", required: false, desc: "Model supports RCAN message signing (default: true)" },
        ],
        example: `{
  "rmn": "RMN-000000000001",
  "registered_at": "2026-03-27T00:00:00.000Z",
  "record_url": "https://robotregistryfoundation.org/v2/models/RMN-000000000001"
}`,
      },
      {
        method: "GET", path: "/v2/models/{rmn}",
        summary: "Get AI model record by RMN",
        description: "Returns the full registry record for an AI model.",
        body: [
          { name: "rmn", type: "path", required: true, desc: "Robot Model Number (RMN-XXXXXXXXXXXX)" },
        ],
        example: `{
  "rmn": "RMN-000000000001",
  "name": "LeWorldModel",
  "version": "v0.1.0",
  "model_family": "world_model",
  "architecture": "jepa",
  "parameter_count_b": 0.015,
  "rcan_compatible": true,
  "registered_at": "2026-03-27T00:00:00.000Z"
}`,
      },
    ],
  },
  // ── AI Harnesses (RHN) ────────────────────────────────────────────────────
  {
    group: "AI Harnesses (RHN)",
    color: "text-yellow-400 border-yellow-500/30 bg-yellow-500/10",
    endpoints: [
      {
        method: "POST", path: "/v2/harnesses/register",
        summary: "Register an AI harness — receive an RHN",
        description: "Assigns the next sequential RHN (Robot Harness Number). A harness is an AI orchestration layer that runs on a robot (e.g. OpenCastor dual-brain). Links to the RMN(s) of models it uses.",
        body: [
          { name: "name",              type: "string",  required: true,  desc: "Harness name" },
          { name: "version",           type: "string",  required: true,  desc: "Semantic version string" },
          { name: "harness_type",      type: "string",  required: true,  desc: "vla | llm_planner | multimodal | hybrid | specialist | safety_monitor | orchestrator | other" },
          { name: "rcan_version",      type: "string",  required: true,  desc: "Minimum RCAN version required (must be \"2.2\")" },
          { name: "description",       type: "string",  required: false, desc: "Human-readable description" },
          { name: "model_ids",         type: "array",   required: false, desc: "RMN[] — models used by this harness" },
          { name: "compatible_robots", type: "array",   required: false, desc: "RRN[] — target robots (empty = universal)" },
          { name: "open_source",       type: "boolean", required: false, desc: "Whether source code is publicly available" },
          { name: "repo_url",          type: "string",  required: false, desc: "Source repository URL" },
          { name: "license",           type: "string",  required: false, desc: "SPDX license identifier" },
        ],
        example: `{
  "rhn": "RHN-000000000001",
  "registered_at": "2026-03-27T00:00:00.000Z",
  "record_url": "https://robotregistryfoundation.org/v2/harnesses/RHN-000000000001"
}`,
      },
      {
        method: "GET", path: "/v2/harnesses/{rhn}",
        summary: "Get AI harness record by RHN",
        description: "Returns the full registry record for an AI harness.",
        body: [
          { name: "rhn", type: "path", required: true, desc: "Robot Harness Number (RHN-XXXXXXXXXXXX)" },
        ],
        example: `{
  "rhn": "RHN-000000000001",
  "name": "OpenCastor Dual-Brain",
  "version": "v2026.3.27.1",
  "harness_type": "hybrid",
  "rcan_version": "2.2",
  "model_ids": ["RMN-000000000001"],
  "open_source": true,
  "registered_at": "2026-03-27T00:00:00.000Z"
}`,
      },
    ],
  },
  // ── Unified Registry ─────────────────────────────────────────────────────
  {
    group: "Unified Registry",
    color: "text-text border-border bg-bg-card",
    endpoints: [
      {
        method: "GET", path: "/v2/registry",
        summary: "List all entities across all types",
        description: "Returns a unified listing of all registered entities (robots, components, models, harnesses), sorted by registration date (newest first). Filter by entity type using ?type=.",
        body: [
          { name: "type",  type: "query",   required: false, desc: "robot | component | model | harness — filter to one entity type" },
          { name: "limit", type: "query",   required: false, desc: "Max results (default: 50, max: 200)" },
        ],
        example: `{
  "entries": [
    {
      "id": "RHN-000000000001",
      "entity_type": "harness",
      "name": "OpenCastor Dual-Brain v2026.3.27.1",
      "registered_at": "2026-03-27T00:00:00.000Z",
      "summary": { "harness_type": "hybrid", "rcan_version": "2.2", "open_source": true }
    }
  ],
  "total": 4,
  "entity_types_count": { "robot": 1, "component": 1, "model": 1, "harness": 1 },
  "rcan_version": "2.2"
}`,
      },
    ],
  },
];

const methodColors: Record<string, string> = {
  GET:    'bg-emerald-500/10 text-emerald-400 border border-emerald-500/30',
  POST:   'bg-blue-500/10 text-blue-400 border border-blue-500/30',
  PUT:    'bg-amber-500/10 text-amber-400 border border-amber-500/30',
  DELETE: 'bg-red-500/10 text-red-400 border border-red-500/30',
};
---

<BaseLayout
  title="API Reference"
  description="Robot Registry Foundation REST API v2 — register and query robots (RRN), components (RCN), AI models (RMN), and harnesses (RHN). RCAN v2.2 §21 entity numbering."
>

  <div class="pt-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-text-muted font-mono mb-8">
      <a href="/" class="hover:text-accent transition-colors">RRF</a>
      <span>/</span>
      <span class="text-text">API Reference</span>
    </nav>

    <!-- Header -->
    <div class="mb-10 pb-8 border-b border-border">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-border bg-bg-card text-xs font-mono text-text-muted mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        v2 · RCAN v2.2 §21
      </div>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-text mb-3">API Reference</h1>
      <p class="text-text-muted max-w-2xl">
        Programmatic access to register and query all four RCAN entity types.
        The v2 API is the only supported API — v1 was removed as of RCAN v2.0.
      </p>

      <!-- Quick info grid -->
      <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="p-3 rounded-lg border border-border bg-bg-card">
          <div class="text-xs text-text-muted mb-1">Base URL</div>
          <code class="text-xs text-accent font-mono break-all">robotregistryfoundation.org</code>
        </div>
        <div class="p-3 rounded-lg border border-border bg-bg-card">
          <div class="text-xs text-text-muted mb-1">Authentication</div>
          <div class="text-xs text-text font-mono">Bearer token (write ops)</div>
          <div class="text-xs text-text-muted">GET endpoints are open</div>
        </div>
        <div class="p-3 rounded-lg border border-border bg-bg-card">
          <div class="text-xs text-text-muted mb-1">Rate limit</div>
          <div class="text-xs text-text font-mono">60 req/min</div>
        </div>
        <div class="p-3 rounded-lg border border-border bg-bg-card">
          <div class="text-xs text-text-muted mb-1">Response format</div>
          <div class="text-xs text-text font-mono">application/json</div>
        </div>
      </div>
    </div>

    <!-- v1 Deprecation notice -->
    <div class="mb-10 p-4 rounded-lg border border-red-500/20 bg-red-500/5">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-400 flex-shrink-0 mt-0.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <div>
          <p class="text-sm font-semibold text-red-400 mb-1">API v1 removed (sunset: 2026-03-27)</p>
          <p class="text-xs text-text-muted">
            The <code class="text-red-400 font-mono">/v1/</code> API (RCAN v1.x era) is gone. Requests to <code class="text-red-400 font-mono">/v1/*</code> return <strong class="text-red-400">HTTP 410 Gone</strong> with a migration hint. All integrations must use <code class="text-accent font-mono">/v2/</code> endpoints documented below.
            OpenCastor users: update to <code class="font-mono text-xs">v2026.3.27.1+</code> — all RRF calls already use v2.
          </p>
        </div>
      </div>
    </div>

    <!-- Entity type legend -->
    <div class="mb-10">
      <h2 class="font-display text-lg font-semibold text-text mb-4">Entity Types — RCAN v2.2 §21.2.2</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {[
          { prefix: "RRN", label: "Robot Registration Number", desc: "Whole robots — the primary unit of identity", color: "text-accent border-accent/30 bg-primary/10" },
          { prefix: "RCN", label: "Robot Component Number",    desc: "Hardware components (CPU, NPU, sensors, actuators)", color: "text-cyan-400 border-cyan-500/30 bg-cyan-500/10" },
          { prefix: "RMN", label: "Robot Model Number",        desc: "AI models used by robots (VLA, LLM, world model)", color: "text-purple-400 border-purple-500/30 bg-purple-500/10" },
          { prefix: "RHN", label: "Robot Harness Number",      desc: "AI harness/orchestration layers (e.g. dual-brain)", color: "text-yellow-400 border-yellow-500/30 bg-yellow-500/10" },
        ].map(e => (
          <div class={`p-3 rounded-lg border ${e.color}`}>
            <div class="font-mono font-bold text-sm mb-1">{e.prefix}</div>
            <div class="text-xs font-medium mb-1">{e.label}</div>
            <div class="text-xs text-text-muted">{e.desc}</div>
            <div class="mt-2 font-mono text-xs text-text-faint">{e.prefix}-000000000001</div>
          </div>
        ))}
      </div>
      <p class="mt-3 text-xs text-text-muted">
        All IDs are sequential, zero-padded 12-digit integers assigned by the registry. Format: <code class="font-mono">{'{PREFIX}'}-{'{'}<em>000000000001</em>{'}'}</code>. IDs are globally unique within their prefix and permanent.
      </p>
    </div>

    <!-- Endpoints by group -->
    {entityEndpoints.map(group => (
      <section class="mb-14">
        <div class="flex items-center gap-3 mb-6">
          <span class={`px-3 py-1 rounded-full border text-xs font-mono font-semibold ${group.color}`}>
            {group.group}
          </span>
          <div class="flex-1 h-px bg-border"></div>
        </div>

        <div class="flex flex-col gap-8">
          {group.endpoints.map(ep => (
            <div class="rounded-xl border border-border bg-bg-card overflow-hidden">
              <!-- Endpoint header -->
              <div class="flex items-center gap-3 p-4 border-b border-border bg-bg">
                <span class={`px-2 py-0.5 rounded text-xs font-mono font-bold border ${methodColors[ep.method]}`}>
                  {ep.method}
                </span>
                <code class="text-sm font-mono text-text break-all">{ep.path}</code>
                <span class="ml-auto text-xs text-text-muted hidden sm:block">{ep.summary}</span>
              </div>

              <div class="p-5 grid md:grid-cols-2 gap-6">
                <!-- Description + params -->
                <div>
                  <p class="text-sm text-text-muted mb-4">{ep.description}</p>

                  {ep.body.length > 0 && (
                    <div>
                      <div class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">
                        {ep.body.some(p => p.type === "path" || p.type === "query") ? "Parameters" : "Request body fields"}
                      </div>
                      <div class="flex flex-col gap-2">
                        {ep.body.map(p => (
                          <div class="flex gap-2 text-xs">
                            <code class="text-accent font-mono flex-shrink-0">{p.name}</code>
                            <span class="text-text-faint font-mono">{p.type}</span>
                            {p.required
                              ? <span class="text-red-400 font-mono flex-shrink-0">required</span>
                              : <span class="text-text-faint font-mono flex-shrink-0">optional</span>
                            }
                            <span class="text-text-muted">{p.desc}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <!-- Example response -->
                <div>
                  <div class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Example response</div>
                  <pre class="group relative bg-bg rounded-lg border border-border p-3 overflow-x-auto text-xs"><code class="text-text-muted font-mono">{ep.example}</code></pre>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- Compliance Intake (RCAN §22-25) -->
    <section class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 rounded-full border text-xs font-mono font-semibold text-accent border-accent/30 bg-primary/10">
          Compliance Intake (RCAN §22-25)
        </span>
        <div class="flex-1 h-px bg-border"></div>
      </div>

      <p class="text-sm text-text-muted mb-4">
        Robots registered under <code class="font-mono text-accent">/v2/robots/register</code> can submit EU AI Act compliance artifacts produced by the <a href="https://www.npmjs.com/package/rcan-ts" class="text-accent hover:underline">rcan-ts</a> 3.2.0+ builders. POST requires a signed body (ML-DSA-65 + Ed25519) against the robot's registered <code class="font-mono text-accent">pq_signing_pub</code> — the signature IS the auth; no Bearer token needed. GET is public for transparency types (safety-benchmark, ifu); Bearer-gated for FRIA and incident-report. Both current and history keys are stored with a 10-year TTL, matching Art. 72 record-keeping obligations.
      </p>

      <!-- §26 deferred callout -->
      <div class="mb-6 p-4 rounded-lg border border-amber-500/20 bg-amber-500/5">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-amber-400 flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <div>
            <p class="text-sm font-semibold text-amber-400 mb-1">§26 EU Register (Art. 49) — deferred</p>
            <p class="text-xs text-text-muted">
              The §26 EU Register intake endpoint is not yet available. It requires an upstream addition of <code class="font-mono text-accent">rmn</code> to the rcan-ts <code class="font-mono text-accent">EuRegisterEntry</code> envelope and will ship in a future release.
            </p>
          </div>
        </div>
      </div>

      <!-- Endpoint table -->
      <div class="mb-6 rounded-xl border border-border bg-bg-card overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-bg border-b border-border">
            <tr>
              <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wider">Endpoint</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wider">RCAN §</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wider">GET access</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border">
              <td class="px-4 py-3 font-mono text-xs text-text break-all"><span class="text-blue-400 font-bold">POST</span> /v2/robots/:rrn/fria</td>
              <td class="px-4 py-3 text-xs text-text-muted">§22 FRIA</td>
              <td class="px-4 py-3 text-xs text-text-muted">Bearer-gated</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-4 py-3 font-mono text-xs text-text break-all"><span class="text-blue-400 font-bold">POST</span> /v2/robots/:rrn/safety-benchmark</td>
              <td class="px-4 py-3 text-xs text-text-muted">§23 Safety Benchmark</td>
              <td class="px-4 py-3 text-xs text-text-muted">public</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-4 py-3 font-mono text-xs text-text break-all"><span class="text-blue-400 font-bold">POST</span> /v2/robots/:rrn/ifu</td>
