          <span class={`px-2 py-0.5 rounded text-xs font-mono font-bold border ${methodColors["POST"]}`}>POST</span>
          <code class="text-sm font-mono text-text break-all">/v2/robots/&#123;rrn&#125;/safety-benchmark</code>
          <span class="ml-auto text-xs text-text-muted hidden sm:block">Example — §23 Safety Benchmark submission</span>
        </div>
