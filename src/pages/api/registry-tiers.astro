---
/**
 * Registry Tier API Specification — RCAN v1.6
 *
 * Documents the registry federation endpoints introduced in RCAN v1.6 (GAP-14).
 *
 * Registry Tiers:
 *   root          — The authoritative root registry (registry.opencastor.com).
 *                   Operates DNSSEC-anchored trust anchors.
 *   authoritative — Organisation-operated registries that are verified by the root.
 *   community     — Self-hosted registries with no root verification.
 *
 * Trust Anchors:
 *   Each registry publishes an Ed25519 public key at /.well-known/rcan-trust-anchor.
 *   The root registry signs authoritative registry trust anchors.
 *   DNSSEC verification proves domain ownership.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';

const endpoints = [
  {
    method: 'GET',
    path: '/api/v1/registries',
    summary: 'List known registries with tier and key fingerprint',
    description:
      'Returns a list of registries known to this RRF instance. ' +
      'Each entry includes the registry domain, trust tier, Ed25519 public key fingerprint, ' +
      'and DNSSEC verification status. Root and authoritative registries include signed trust anchors.',
    auth: false,
    params: [
      {
        name: 'tier',
        in: 'query',
        type: 'string',
        required: false,
        desc: 'Filter by tier: root | authoritative | community',
      },
      {
        name: 'verified_only',
        in: 'query',
        type: 'boolean',
        required: false,
        default: 'false',
        desc: 'If true, return only root and authoritative registries',
      },
    ],
    response: {
      status: 200,
      example: `{
  "registries": [
    {
      "domain": "registry.opencastor.com",
      "tier": "root",
      "key_fingerprint": "sha256:AbCdEf1234567890abcdef1234567890abcdef1234567890abcdef1234567890",
      "dnssec_verified": true,
      "robots_count": 12,
      "registered_at": "2025-01-01T00:00:00Z",
      "description": "OpenCastor Root Registry — operated by ContinuonAI"
    },
    {
      "domain": "robots.example.org",
      "tier": "authoritative",
      "key_fingerprint": "sha256:1234abcd...",
      "dnssec_verified": true,
      "verified_by": "registry.opencastor.com",
      "verified_at": "2026-03-01T00:00:00Z",
      "robots_count": 3
    },
    {
      "domain": "my-lab.local",
      "tier": "community",
      "key_fingerprint": null,
      "dnssec_verified": false,
      "robots_count": 1
    }
  ],
  "total": 3
}`,
    },
  },
  {
    method: 'GET',
    path: '/api/v1/registries/{domain}/trust-anchor',
    summary: 'Get public key PEM and DNSSEC verification status for a registry',
    description:
      'Returns the Ed25519 public key in PEM format and DNSSEC verification status ' +
      'for the specified registry domain. ' +
      'For authoritative registries, the root registry signature is included. ' +
      'Robots can use this endpoint to populate their TrustAnchorCache (GAP-14).',
    auth: false,
    params: [
      {
        name: 'domain',
        in: 'path',
        type: 'string',
        required: true,
        desc: 'Registry domain, e.g. registry.opencastor.com or robots.example.org',
      },
    ],
    response: {
      status: 200,
      example: `{
  "domain": "registry.opencastor.com",
  "tier": "root",
  "public_key_pem": "-----BEGIN PUBLIC KEY-----\\nMCowBQYDK2VwAyEA...\\n-----END PUBLIC KEY-----",
  "key_algorithm": "Ed25519",
  "key_id": "kid-root-2026-01-001",
  "key_valid_from": "2026-01-01T00:00:00Z",
  "key_expires_at": null,
  "dnssec_verified": true,
  "dnssec_checked_at": "2026-03-17T10:00:00Z",
  "root_signature": null,
  "rcan_version": "2.2"
}`,
    },
    errors: [
      { status: 404, detail: 'Registry not found or not tracked by this RRF instance' },
    ],
  },
  {
    method: 'POST',
    path: '/api/v1/registries/{domain}/verify',
    summary: 'Root registry: verify an authoritative registry',
    description:
      'Root-registry-only endpoint. Verifies a candidate authoritative registry by:\n' +
      '1. Fetching its /.well-known/rcan-trust-anchor (Ed25519 public key)\n' +
      '2. Verifying DNSSEC for the domain\n' +
      '3. Signing the registry\'s public key with the root private key\n' +
      '4. Recording the verification in the registry database\n\n' +
      'Only callable by authenticated root registry administrators. ' +
      'Returns the root-signed trust anchor for the verified registry.',
    auth: true,
    auth_note: 'Requires root registry admin JWT (registry_admin: true claim)',
    params: [
      {
        name: 'domain',
        in: 'path',
        type: 'string',
        required: true,
        desc: 'Domain of the registry to verify, e.g. robots.example.org',
      },
    ],
    request_body: `{
  "public_key_pem": "-----BEGIN PUBLIC KEY-----\\nMCowBQYDK2VwAyEA...\\n-----END PUBLIC KEY-----",
  "key_id": "kid-example-2026-03-001",
  "contact_email": "admin@example.org",
  "description": "Example Organisation Robot Registry"
}`,
    response: {
      status: 200,
      example: `{
  "domain": "robots.example.org",
  "tier": "authoritative",
  "key_id": "kid-example-2026-03-001",
  "root_signature": "base64-encoded-root-signature...",
  "verified_by": "registry.opencastor.com",
  "verified_at": "2026-03-17T18:00:00Z",
  "dnssec_verified": true,
  "message": "Registry robots.example.org verified and signed by root"
}`,
    },
    errors: [
      { status: 400, detail: 'Invalid public key PEM or key_id' },
      { status: 401, detail: 'Not authenticated as root registry admin' },
      { status: 403, detail: 'Caller is not the root registry' },
      { status: 422, detail: 'DNSSEC verification failed for domain' },
      { status: 409, detail: 'Registry already verified — use PATCH to rotate key' },
    ],
  },
];
---

<BaseLayout
  title="Registry Tier API — RCAN v1.6"
  description="Federation API for RCAN v1.6 registry tiers, trust anchors, and cross-registry verification (GAP-14)"
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold mb-3">Registry Tier API <span class="text-sm font-normal text-gray-500 ml-2">RCAN v1.6</span></h1>
      <p class="text-gray-600 mb-4">
        Federation endpoints for RCAN v1.6 registry trust hierarchy (GAP-14).
        Enables cross-registry command validation via signed trust anchors.
      </p>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <h2 class="font-semibold text-blue-800 mb-2">Registry Tiers</h2>
        <ul class="text-sm text-blue-700 space-y-1">
          <li><strong>root</strong> — Single authoritative root (<code>registry.opencastor.com</code>). DNSSEC-anchored, signs authoritative registries.</li>
          <li><strong>authoritative</strong> — Organisation registries verified by root. Carry root signature in trust anchor.</li>
          <li><strong>community</strong> — Self-hosted, no root verification. Used for local/private deployments.</li>
        </ul>
      </div>

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <h2 class="font-semibold text-yellow-800 mb-2">Status: Specification (v1.6)</h2>
        <p class="text-sm text-yellow-700">
          These endpoints are specified for RCAN v1.6. The root registry endpoint
          (<code>POST /api/v1/registries/{'{domain}'}/verify</code>) is only active on
          <code>registry.opencastor.com</code>. Community RRF instances expose GET-only
          trust anchor lookups.
        </p>
      </div>
    </div>

    {endpoints.map((ep) => (
      <section class="mb-12 border border-gray-200 rounded-lg overflow-hidden">
        <div class={`flex items-center gap-3 px-5 py-3 ${
          ep.method === 'GET' ? 'bg-green-50 border-b border-green-200' :
          ep.method === 'POST' ? 'bg-blue-50 border-b border-blue-200' :
          'bg-gray-50 border-b border-gray-200'
        }`}>
          <span class={`font-mono font-bold text-sm px-2 py-0.5 rounded ${
            ep.method === 'GET' ? 'bg-green-600 text-white' :
            ep.method === 'POST' ? 'bg-blue-600 text-white' :
            'bg-gray-600 text-white'
          }`}>{ep.method}</span>
          <code class="font-mono text-sm font-semibold">{ep.path}</code>
          {ep.auth && (
            <span class="ml-auto text-xs text-orange-700 bg-orange-100 px-2 py-0.5 rounded border border-orange-200">🔒 Auth required</span>
          )}
        </div>

        <div class="p-5">
          <h3 class="font-semibold text-lg mb-1">{ep.summary}</h3>
          <p class="text-gray-600 text-sm mb-4 whitespace-pre-line">{ep.description}</p>

          {ep.auth_note && (
            <div class="bg-orange-50 border border-orange-200 rounded p-3 mb-4 text-sm text-orange-800">
              {ep.auth_note}
            </div>
          )}

          {ep.params && ep.params.length > 0 && (
            <div class="mb-4">
              <h4 class="font-medium text-sm mb-2 text-gray-700">Parameters</h4>
              <table class="w-full text-sm border border-gray-200 rounded">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="text-left px-3 py-2 font-medium">Name</th>
                    <th class="text-left px-3 py-2 font-medium">In</th>
                    <th class="text-left px-3 py-2 font-medium">Type</th>
                    <th class="text-left px-3 py-2 font-medium">Required</th>
                    <th class="text-left px-3 py-2 font-medium">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {ep.params.map((p, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                      <td class="px-3 py-2 font-mono text-xs">{p.name}</td>
                      <td class="px-3 py-2 text-gray-500">{p.in || 'query'}</td>
                      <td class="px-3 py-2 text-gray-500">{p.type}</td>
                      <td class="px-3 py-2">{p.required ? <span class="text-red-600">Yes</span> : <span class="text-gray-400">No</span>}</td>
                      <td class="px-3 py-2 text-gray-600">{p.desc}{p.default && <span class="text-gray-400 ml-1">(default: {p.default})</span>}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {ep.request_body && (
            <div class="mb-4">
              <h4 class="font-medium text-sm mb-2 text-gray-700">Request Body</h4>
              <pre class="bg-gray-900 text-green-300 rounded p-3 text-xs overflow-x-auto">{ep.request_body}</pre>
            </div>
          )}

          <div class="mb-4">
            <h4 class="font-medium text-sm mb-2 text-gray-700">Response <span class="text-green-600">{ep.response.status}</span></h4>
            <pre class="bg-gray-900 text-green-300 rounded p-3 text-xs overflow-x-auto">{ep.response.example}</pre>
          </div>

          {ep.errors && ep.errors.length > 0 && (
            <div>
              <h4 class="font-medium text-sm mb-2 text-gray-700">Error Responses</h4>
              <ul class="text-sm space-y-1">
                {ep.errors.map((e) => (
                  <li class="flex gap-2">
                    <span class="text-red-600 font-mono font-semibold">{e.status}</span>
                    <span class="text-gray-600">{e.detail}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
