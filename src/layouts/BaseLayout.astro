---
interface Props {
  title: string;
  description?: string;
}

import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const {
  title,
  description = "The Robot Registry Foundation assigns globally unique identifiers to robots worldwide — independent, open infrastructure for robot identity.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://robotregistryfoundation.org");
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Robot Registry Foundation</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Robot Registry Foundation`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Robot Registry Foundation" />
    <meta property="og:image" content="https://robotregistryfoundation.org/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://robotregistryfoundation.org/og-image.png" />
  </head>
  <body class="bg-bg text-text font-sans antialiased min-h-screen flex flex-col">
    <!-- Grid background -->
    <div class="fixed inset-0 bg-grid-pattern bg-grid opacity-100 pointer-events-none z-0"></div>
    <!-- Hero glow -->
    <div class="fixed inset-0 bg-hero-glow pointer-events-none z-0"></div>
    <SiteHeader />
    <main class="flex-1 w-full max-w-7xl mx-auto px-6 pt-20 pb-16 z-10 relative">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
