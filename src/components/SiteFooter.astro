---
---

<footer class="border-t border-border bg-bg-alt/60 py-16 mt-24 relative z-10">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Logo + tagline -->
    <div class="mb-12">
      <a href="/" class="flex items-center gap-3 w-fit mb-4 group">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 group-hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.7)] transition-all">
          <path d="M16 2L4 7v9c0 6.627 5.373 12 12 12s12-5.373 12-12V7L16 2z" fill="#1e40af" stroke="#3b82f6" stroke-width="1"/>
          <rect x="10" y="10" width="12" height="10" rx="2" fill="none" stroke="#93c5fd" stroke-width="1.2"/>
          <circle cx="13" cy="14" r="1.5" fill="#60a5fa"/>
          <circle cx="19" cy="14" r="1.5" fill="#60a5fa"/>
          <path d="M13 18h6" stroke="#60a5fa" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span class="font-mono text-sm font-medium tracking-widest text-text">Robot Registry Foundation</span>
      </a>
      <p class="text-text-muted text-sm max-w-sm leading-relaxed">
        Independent infrastructure for robot identity. Neutral, open, federated.
      </p>
      <p class="text-text-faint text-xs mt-2 font-mono">
        Proposed independent foundation in formation · Not yet a legal entity
      </p>
    </div>

    <!-- Link grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-text-faint mb-4 font-mono">Registry</h4>
        <ul class="space-y-2.5">
          <li><a href="/registry/" class="text-sm text-text-muted hover:text-accent transition-colors">Browse Registry</a></li>
          <li><a href="/registry/submit/" class="text-sm text-text-muted hover:text-accent transition-colors">Register a Robot</a></li>
          <li><a href="/registry/lookup/" class="text-sm text-text-muted hover:text-accent transition-colors">RRN Lookup</a></li>
          <li><a href="/verification/" class="text-sm text-text-muted hover:text-accent transition-colors">Verification</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-text-faint mb-4 font-mono">Foundation</h4>
        <ul class="space-y-2.5">
          <li><a href="/governance/" class="text-sm text-text-muted hover:text-accent transition-colors">Governance Charter</a></li>
          <li><a href="/governance/#board" class="text-sm text-text-muted hover:text-accent transition-colors">Board & Membership</a></li>
          <li><a href="/governance/#get-involved" class="text-sm text-text-muted hover:text-accent transition-colors">Co-found the RRF</a></li>
          <li><a href="/about/" class="text-sm text-text-muted hover:text-accent transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-text-faint mb-4 font-mono">Protocol</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="https://rcan.dev" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors flex items-center gap-1">
              RCAN Spec
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </li>
          <li>
            <a href="https://rcan.dev/docs" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors flex items-center gap-1">
              SDKs
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </li>
          <li>
            <a href="https://rcan.dev/conformance" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors flex items-center gap-1">
              Conformance
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </li>
          <li><a href="/rcan-integration/" class="text-sm text-text-muted hover:text-accent transition-colors">RCAN Integration →</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-text-faint mb-4 font-mono">Resources</h4>
        <ul class="space-y-2.5">
          <li><a href="/api/" class="text-sm text-text-muted hover:text-accent transition-colors">API Docs</a></li>
          <li>
            <a href="https://github.com/craigm26/RobotRegistryFoundation" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors flex items-center gap-1">
              GitHub
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </li>
          <li>
            <a href="https://opencastor.com" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors flex items-center gap-1">
              OpenCastor SDK
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </li>
          <li><span class="text-sm text-text-faint">Blog (coming soon)</span></li>
          <li><a href="/governance/#eu-ai-act" class="text-sm text-text-muted hover:text-accent transition-colors">EU AI Act Guide</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border pt-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="text-xs text-text-faint font-mono">
        Robot Registry Foundation · Proposed independent foundation in formation · Not yet a legal entity
      </p>
      <p class="text-xs text-text-faint">
        © 2026 Robot Registry Foundation. Registry data
        <a href="https://creativecommons.org/publicdomain/zero/1.0/" class="text-accent/70 hover:text-accent transition-colors" target="_blank" rel="noopener noreferrer">CC0</a>.
        Specification
        <a href="https://creativecommons.org/licenses/by/4.0/" class="text-accent/70 hover:text-accent transition-colors" target="_blank" rel="noopener noreferrer">CC BY 4.0</a>.
      </p>
    </div>
  </div>
</footer>
