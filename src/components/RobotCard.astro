---
import VerificationBadge from './VerificationBadge.astro';
import RRNBadge from './RRNBadge.astro';

interface Props {
  rrn: string;
  name: string;
  manufacturer: string;
  description: string;
  verification_status: 'community' | 'verified' | 'manufacturer' | 'certified';
  tags?: string[];
  status?: string;
}

const { rrn, name, manufacturer, description, verification_status, tags = [], status = 'active' } = Astro.props;

const statusDot: Record<string, string> = {
  active: 'bg-emerald-500',
  retired: 'bg-gray-500',
  prototype: 'bg-amber-500',
  concept: 'bg-purple-500',
};
---

<a
  href={`/registry/${rrn}/`}
  class="group block bg-bg-card border border-border hover:border-border-strong rounded-xl p-5 transition-all duration-200 hover:shadow-[0_0_30px_rgba(59,130,246,0.08)] hover:-translate-y-0.5"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex items-center gap-2 flex-wrap">
      <RRNBadge rrn={rrn} />
      <VerificationBadge status={verification_status} size="sm" />
    </div>
    <div class:list={["w-2 h-2 rounded-full mt-1 flex-shrink-0", statusDot[status] ?? 'bg-gray-500']} title={`Status: ${status}`}></div>
  </div>

  <h3 class="font-display text-lg font-semibold text-text group-hover:text-accent transition-colors leading-tight mb-0.5">
    {name}
  </h3>
  <p class="text-sm text-text-muted mb-3 font-mono">{manufacturer}</p>
  <p class="text-sm text-text-muted leading-relaxed line-clamp-2">{description}</p>

  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.slice(0, 4).map(tag => (
        <span class="text-xs px-2 py-0.5 rounded bg-accent/8 text-text-faint border border-accent/10 font-mono">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
